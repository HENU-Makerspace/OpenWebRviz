[Unit]
Description=WebBot Media Reverse SSH Tunnel
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
SyslogIdentifier=webbot-media-tunnel
StandardOutput=journal
StandardError=journal
ExecStart=%h/bin/webbot-tunnel.sh %h/.ssh/id_ed25519_webbot_cloud root@182.43.86.126 -R 127.0.0.1:18088:127.0.0.1:8088 -R 127.0.0.1:18000:127.0.0.1:8000 -R 127.0.0.1:19100:127.0.0.1:19100 -R 127.0.0.1:19110:127.0.0.1:19110
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
